HOST_APP_TYPE = offload_legacy
CHIP_TYPE     = single_chip
SRCS = src/offload_legacy_single_chip.c
DEV_APP = snax-test-integration

DEVICE_APPS_WITH_MEMPOOL_IMAGE = gemm-msplit-4cluster-1chip

BINGO_HOST ?= 0 # True to include the bingo runtime
INCL_DEVICE_BINARY ?= 1 # True to include the device binary

# those are the legacy apps that we want to keep supporting and for ci
DEVICE_APPS = snax-test-integration
DEVICE_APPS += snax-test-bingo-alloc
DEVICE_APPS += snax-xdma-copy
DEVICE_APPS += snax-xdma-hazard
DEVICE_APPS += versacore-matmul-profile-1cluster-4chip
DEVICE_APPS += versacore-matmul-profile-2cluster-4chip

include ../../common.mk

# These device apps preload memory-chip data through a mempool.bin image
# generated by their datagen. Stage it beside the host ELF for target/sim/apps.
ifneq ($(filter $(DEV_APP),$(DEVICE_APPS_WITH_MEMPOOL_IMAGE)),)
MEMPOOL_SRC = $(DEVICE_DIR)/apps/snax/$(DEV_APP)/data/mempool.bin
finalize-build: $(BUILDDIR)/mempool.bin
$(BUILDDIR)/mempool.bin: $(MEMPOOL_SRC) | $(BUILDDIR)
	cp -f $< $@
endif
