{
    sim_cfg_name: "sim_rtl_pll",
    // Sim with RTL models
    sim_with_rtl: true
    // Do not replace the Mem macros
    sim_with_mem_macro: false
    // Do not use netlist
    sim_with_netlist: false
    // Sim with interposer
    sim_with_interposer: false
    // Sim with PLL
    sim_with_pll: true
}
