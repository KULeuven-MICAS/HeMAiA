/*
!/Makefile
!/.gitignore

!/ci/
/ci/*
!/ci/local_ci/
/ci/local_ci/*
# One suite subdir per tapeout RTL cfg; each keeps its own driver + task list
# (the task_<idx>/ run dirs it produces stay ignored).
!/ci/local_ci/tapeout/
/ci/local_ci/tapeout/*
!/ci/local_ci/tapeout/run_local_ci.py
!/ci/local_ci/tapeout/task_local_ci.yaml
!/ci/local_ci/tapeout_1c_simd/
/ci/local_ci/tapeout_1c_simd/*
!/ci/local_ci/tapeout_1c_simd/run_local_ci.py
!/ci/local_ci/tapeout_1c_simd/task_local_ci.yaml
!/ci/local_ci/tapeout_2c/
/ci/local_ci/tapeout_2c/*
!/ci/local_ci/tapeout_2c/run_local_ci.py
!/ci/local_ci/tapeout_2c/task_local_ci.yaml
!/ci/local_ci/tapeout_2c_simd/
/ci/local_ci/tapeout_2c_simd/*
!/ci/local_ci/tapeout_2c_simd/run_local_ci.py
!/ci/local_ci/tapeout_2c_simd/task_local_ci.yaml
!/ci/git_ci/
/ci/git_ci/*
!/ci/git_ci/run_git_ci.py
!/ci/git_ci/task_git_ci.yaml
!/ci/netlist_ci/
/ci/netlist_ci/*
!/ci/netlist_ci/README.md
!/ci/netlist_ci/run_netlist_ci.py

!/sweep/
/sweep/*
!/sweep/xdma/
/sweep/xdma/*
!/sweep/xdma/run_xdma_sweep.py
!/sweep/xdma/gather_xdma_luts.py
!/sweep/xdma/xdma_lut_report.py
!/sweep/xdma/task_xdma.yaml
!/sweep/ara/
/sweep/ara/*
!/sweep/ara/run_ara_sweep.py
!/sweep/ara/gather_ara_luts.py
!/sweep/ara/ara_lut_report.py
!/sweep/ara/task_ara.yaml
!/sweep/gemm/
/sweep/gemm/*
!/sweep/gemm/run_gemm_sweep.py
!/sweep/gemm/gather_gemm_luts.py
!/sweep/gemm/task_gemm.yaml

!/test/
/test/*
!/test/README.md
!/test/0_start_single_chiplet_sim.py
!/test/1_start_multi_chiplet_sim.py
!/test/2_start_tapeout_sim.py
